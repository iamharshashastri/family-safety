{
  "appId": "tech.velocomputing.familysafety",
  "productName": "FamilySafety Child",
  "asar": true,
  "files": [
    "src/**",
    "node_modules/**",
    "package.json",
    "!README.md",
    "!README.*",
    "!LICENSE*",
    "!web/management.html",
    "!index.html"
  ],
  "directories": {
    "buildResources": "build"
  },
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": [
          "x64"
        ]
      }
    ]
  },
  "nsis": {
    "oneClick": false,
    "perMachine": false,
    "allowElevation": true,
    "createDesktopShortcut": "always",
    "createStartMenuShortcut": true
  }
}
